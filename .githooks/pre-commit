#!/usr/bin/env bash
# pre-commit hook — guards the content-flip invariant.
#
# As of 2026-04-24 content/<topic>.json is source of truth; <topic>.html
# files are regenerated by `scripts/rebuild.mjs` (fix mode) via
# `scripts/test-roundtrip.mjs --fix`. Hand-editing <topic>.html without
# updating the matching content/<topic>.json means the next rebuild
# silently overwrites your HTML edit. This hook catches the mismatch
# at commit time.
#
# It stages nothing on its own. It only fails the commit when a topic
# HTML has drifted from its content JSON, and tells you what to do next.
#
# INSTALL (one-time, per clone):
#   git config core.hooksPath .githooks
#
# BYPASS (if you know what you're doing):
#   git commit --no-verify
#
# Dependencies: node (>=20), already required by the repo.

set -eu

# Only run if a topic .html or its content/*.json is staged. If neither
# touched, no roundtrip risk — skip the check.
CHANGED=$(git diff --cached --name-only --diff-filter=ACMR \
  | grep -E '^(content/[^/]+\.json|[^/]+\.html)$' \
  || true)

if [ -z "$CHANGED" ]; then
  exit 0
fi

# Resolve repo root so the hook works from any worktree / subdirectory.
ROOT=$(git rev-parse --show-toplevel)

# Run the strict gate. This renders each content/<topic>.json via
# render-topic.mjs and compares to the on-disk <topic>.html; any drift
# is a hard failure.
cd "$ROOT"
if ! node scripts/test-roundtrip.mjs > /tmp/mvnb-precommit-roundtrip.log 2>&1; then
  echo
  echo "pre-commit: test-roundtrip FAILED — content/*.json and <topic>.html are out of sync."
  echo
  sed 's/^/  /' /tmp/mvnb-precommit-roundtrip.log
  echo
  echo "If you edited a <topic>.html directly:"
  echo "  • discard the HTML edits and reapply them as JSON changes, OR"
  echo "  • run \`node scripts/extract-topic.mjs <topic>\` to backport the HTML into the JSON,"
  echo "  • then run \`node scripts/rebuild.mjs --fix\` to regenerate the HTML canonically."
  echo
  echo "If you edited a content/<topic>.json:"
  echo "  • run \`node scripts/rebuild.mjs --fix\` to rewrite the HTML, then re-stage both files."
  echo
  echo "If you know the roundtrip is fine and want to override this gate:"
  echo "  git commit --no-verify"
  exit 1
fi

exit 0
